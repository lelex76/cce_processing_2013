      "source": [
        "CELDA 5 — Definir N2\n",
        "\n",
        "17 combinaciones:"
      ],
      "metadata": {
        "id": "NhSaUOKAycec"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# =====================================================\n",
        "# N2\n",
        "# 17 combinaciones\n",
        "# =====================================================\n",
        "\n",
        "\n",
        "combinaciones_N2={\n",
        "\n",
        "\"A+C+P\":(\"A\",\"C\",\"P\"),\n",
        "\n",
        "\"B+M+R\":(\"B\",\"M\",\"R\"),\n",
        "\n",
        "\"H+I+S\":(\"H\",\"I\",\"S\"),\n",
        "\n",
        "\"G+L+E\":(\"G\",\"L\",\"E\"),\n",
        "\n",
        "\"T+J+W\":(\"T\",\"J\",\"W\"),\n",
        "\n",
        "\"F+O+Q\":(\"F\",\"O\",\"Q\"),\n",
        "\n",
        "\"D+X+V\":(\"D\",\"X\",\"V\"),\n",
        "\n",
        "\"E+A+H\":(\"E\",\"A\",\"H\"),\n",
        "\n",
        "\"C+Z+L\":(\"C\",\"Z\",\"L\"),\n",
        "\n",
        "\"N+R+I\":(\"N\",\"R\",\"I\"),\n",
        "\n",
        "\"S+P+K\":(\"S\",\"P\",\"K\"),\n",
        "\n",
        "\"F+V+G\":(\"F\",\"V\",\"G\"),\n",
        "\n",
        "\"Q+B+X\":(\"Q\",\"B\",\"X\"),\n",
        "\n",
        "\"W+O+T\":(\"W\",\"O\",\"T\"),\n",
        "\n",
        "\"D+J+Z\":(\"D\",\"J\",\"Z\"),\n",
        "\n",
        "\"H+S+M\":(\"H\",\"S\",\"M\"),\n",
        "\n",
        "\"L+O+W\":(\"L\",\"O\",\"W\")\n",
        "\n",
        "}\n",
        "\n",
        "\n",
        "print(\n",
        "\"Combinaciones N2:\",\n",
        "len(combinaciones_N2)\n",
        ")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "3fVIMI8QzStO",
        "outputId": "001269aa-db0f-4f44-9911-828ccfef9db3"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
