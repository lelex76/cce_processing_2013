    {
      "cell_type": "code",
      "source": [
        "# Guardar el alfabeto\n",
        "\n",
        "with open(\n",
        "    \"TmaqT_N1.json\",\n",
        "    \"w\"\n",
        ") as archivo:\n",
        "\n",
