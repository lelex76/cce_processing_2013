    {
      "cell_type": "markdown",
      "source": [
        "N5"
      ],
      "metadata": {
        "id": "t2LDd-tG6GNT"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n",
        "# =====================================\n",
        "# N5 combinaciones sistémicas\n",
        "# =====================================\n",
        "\n",
        "combinaciones_N5 = {\n",
        "\n",
        "\"LM\":(\"L\",\"M\"),\n",
        "\"NR\":(\"N\",\"R\"),\n",
        "\"HW\":(\"H\",\"W\"),\n",
        "\"SP\":(\"S\",\"P\"),\n",
        "\"MQ\":(\"M\",\"Q\"),\n",
        "\"CL\":(\"C\",\"L\"),\n",
        "\"KV\":(\"K\",\"V\"),\n",
        "\"TW\":(\"T\",\"W\"),\n",
        "\"FJ\":(\"F\",\"J\")\n",
        "\n",
        "}\n",
        "\n",
        "\n",
        "\n",
        "# =====================================\n",
        "# Operador binario\n",
        "# dos matrices -> 9 negros\n",
        "# =====================================\n",
        "\n",
        "def omega2(A,B):\n",
        "\n",
        "    A=np.array(A)\n",
        "    B=np.array(B)\n",
        "\n",
        "\n",
        "    votos=A+B\n",
        "\n",
        "\n",
        "    posiciones=[]\n",
        "\n",
        "\n",
        "    for i in range(5):\n",
        "\n",
        "        for j in range(5):\n",
        "\n",
        "            posiciones.append(\n",
        "                (\n",
        "                votos[i,j],\n",
        "                i,\n",
        "                j\n",
        "                )\n",
        "            )\n",
        "\n",
        "\n",
        "    posiciones.sort(reverse=True)\n",
        "\n",
        "\n",
        "\n",
        "    M=np.zeros((5,5),dtype=int)\n",
        "\n",
        "\n",
        "    for n in range(9):\n",
        "\n",
        "        _,i,j=posiciones[n]\n",
        "\n",
        "        M[i,j]=1\n",
        "\n",
        "\n",
        "    return M\n",
        "\n",
        "\n",
        "\n",
        "# =====================================\n",
        "# Crear N5\n",
        "# =====================================\n",
        "\n",
        "N5={}\n",
        "\n",
        "\n",
        "for nombre,(a,b) in combinaciones_N5.items():\n",
        "\n",
        "    N5[nombre]=omega2(\n",
        "        tmaqT[a][\"patron\"],\n",
        "        tmaqT[b][\"patron\"]\n",
        "    )\n",
        "\n",
        "\n",
        "print(\"N5 creado\")\n",
        "print(len(N5))\n",
        "\n",
        "\n",
        "\n",
        "# =====================================\n",
        "# Visualizar\n",
        "# =====================================\n",
        "\n",
        "fig,axes=plt.subplots(\n",
        "    3,\n",
        "    3,\n",
        "    figsize=(8,8)\n",
        ")\n",
        "\n",
        "\n",
        "axes=axes.flatten()\n",
        "\n",
        "\n",
        "for ax,(nombre,M) in zip(\n",
        "    axes,\n",
        "    N5.items()\n",
        "):\n",
        "\n",
        "    ax.imshow(\n",
        "        M,\n",
        "        cmap=\"binary\"\n",
        "    )\n",
        "\n",
        "    ax.set_title(nombre)\n",
        "\n",
        "    ax.axis(\"off\")\n",
        "\n",
        "\n",
        "\n",
        "plt.suptitle(\n",
        "    \"N5 - Combinaciones sistémicas\"\n",
        ")\n",
        "\n",
        "plt.tight_layout()\n",
        "\n",
        "plt.show()"
      ],
