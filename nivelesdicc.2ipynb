          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "Asume que ya tienes creado tu N1 tmaqT con las 24 matrices 5×5.\n",
        "\n",
        "Este código hace:\n",
        "\n",
        "N2 = 17 combinaciones\n",
        "Operador Ω(A,B,C)\n",
        "Superposición\n",
        "Votación celular\n",
        "Mantiene exactamente 9 cuadrados negros\n",
        "Visualiza las 17 morfologías emergentes"
      ],
      "metadata": {
        "id": "iQEvIExnFyA-"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n",
        "# ============================================\n",
        "# N2 - Combinaciones morfológicas (17)\n",
        "# ============================================\n",
        "\n",
        "combinaciones_N2 = {\n",
        "\n",
        "\"A+C+P\": (\"A\",\"C\",\"P\"),\n",
        "\"B+M+R\": (\"B\",\"M\",\"R\"),\n",
        "\"H+I+S\": (\"H\",\"I\",\"S\"),\n",
        "\"G+L+E\": (\"G\",\"L\",\"E\"),\n",
        "\"T+J+W\": (\"T\",\"J\",\"W\"),\n",
        "\"F+O+Q\": (\"F\",\"O\",\"Q\"),\n",
        "\"D+X+V\": (\"D\",\"X\",\"V\"),\n",
        "\"E+A+H\": (\"E\",\"A\",\"H\"),\n",
        "\"C+Z+L\": (\"C\",\"Z\",\"L\"),\n",
        "\"N+R+I\": (\"N\",\"R\",\"I\"),\n",
        "\"S+P+K\": (\"S\",\"P\",\"K\"),\n",
        "\"F+V+G\": (\"F\",\"V\",\"G\"),\n",
        "\"Q+B+X\": (\"Q\",\"B\",\"X\"),\n",
        "\"W+O+T\": (\"W\",\"O\",\"T\"),\n",
        "\"D+J+Z\": (\"D\",\"J\",\"Z\"),\n",
        "\"H+S+M\": (\"H\",\"S\",\"M\"),\n",
        "\"L+O+W\": (\"L\",\"O\",\"W\")\n",
        "\n",
        "}\n",
        "\n",
        "\n",
        "# ============================================\n",
        "# Operador Ω\n",
        "# Consenso celular + 9 negros\n",
        "# ============================================\n",
        "\n",
        "def omega(A,B,C):\n",
        "\n",
        "    A=np.array(A)\n",
        "    B=np.array(B)\n",
        "    C=np.array(C)\n",
        "\n",
        "\n",
        "    # superposición\n",
        "    votos=A+B+C\n",
        "\n",
        "\n",
        "    # ordenar por cantidad de coincidencias\n",
        "\n",
        "    posiciones=[]\n",
        "\n",
        "\n",
        "    for i in range(5):\n",
        "\n",
        "        for j in range(5):\n",
        "\n",
        "            posiciones.append(\n",
        "                (\n",
        "                    votos[i,j],\n",
        "                    i,\n",
        "                    j\n",
        "                )\n",
        "            )\n",
        "\n",
        "\n",
        "    posiciones.sort(\n",
        "        reverse=True\n",
        "    )\n",
        "\n",
        "\n",
        "    # matriz resultado\n",
        "\n",
        "    M=np.zeros(\n",
        "        (5,5),\n",
        "        dtype=int\n",
        "    )\n",
        "\n",
        "\n",
        "    # seleccionar exactamente 9\n",
        "\n",
        "    for n in range(9):\n",
        "\n",
        "        voto,i,j=posiciones[n]\n",
        "\n",
        "        M[i,j]=1\n",
        "\n",
        "\n",
        "    return M\n",
        "\n",
        "\n",
        "\n",
        "# ============================================\n",
        "# Crear N2\n",
        "# ============================================\n",
        "\n",
        "N2={}\n",
        "\n",
        "\n",
        "for nombre,(a,b,c) in combinaciones_N2.items():\n",
        "\n",
        "\n",
        "    N2[nombre]=omega(\n",
        "\n",
        "        tmaqT[a][\"patron\"],\n",
        "\n",
        "        tmaqT[b][\"patron\"],\n",
        "\n",
        "        tmaqT[c][\"patron\"]\n",
        "\n",
        "    )\n",
        "\n",
        "\n",
        "print(\"N2 creado\")\n",
        "print(\"Cantidad:\",len(N2))\n",
        "\n",
        "\n",
        "# ============================================\n",
        "# Verificación\n",
        "# ============================================\n",
        "\n",
        "print(\"\\nVerificación de cuadrados negros:\\n\")\n",
        "\n",
        "\n",
        "for nombre,matriz in N2.items():\n",
        "\n",
        "    print(\n",
        "        nombre,\n",
        "        \"→\",\n",
        "        np.sum(matriz),\n",
        "        \"negros\"\n",
        "    )\n",
        "\n",
        "\n",
        "\n",
        "# ============================================\n",
        "# Visualización N2\n",
        "# ============================================\n",
        "\n",
        "fig,axes=plt.subplots(\n",
        "    5,\n",
        "    4,\n",
        "    figsize=(10,12)\n",
        ")\n",
        "\n",
        "\n",
        "axes=axes.flatten()\n",
        "\n",
        "\n",
        "\n",
        "for ax,(nombre,matriz) in zip(\n",
        "    axes,\n",
        "    N2.items()\n",
        "):\n",
        "\n",
        "    ax.imshow(\n",
        "        matriz,\n",
        "        cmap=\"binary\",\n",
        "        interpolation=\"nearest\"\n",
        "    )\n",
        "\n",
        "\n",
        "    ax.set_title(\n",
        "        nombre,\n",
        "        fontsize=12\n",
        "    )\n",
        "\n",
        "    ax.set_xticks(range(5))\n",
        "    ax.set_yticks(range(5))\n",
        "    ax.grid(True)\n",
        "\n",
        "\n",
        "\n",
        "for ax in axes[len(N2):]:\n",
        "\n",
        "    ax.axis(\"off\")\n",
        "\n",
        "\n",
        "\n",
        "plt.suptitle(\n",
        "    \"TmaqT - Nivel N2\\nMorfologías emergentes Ω(A,B,C)\",\n",
        "    fontsize=16\n",
        ")\n",
        "\n",
        "\n",
        "plt.tight_layout()\n",
        "\n",
        "plt.show()"
      ],
      "metadata": {
