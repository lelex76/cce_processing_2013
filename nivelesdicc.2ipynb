    {
      "cell_type": "code",
      "source": [
        "# =====================================================\n",
        "# VISUALIZACIÓN N1\n",
        "# =====================================================\n",
        "\n",
        "\n",
        "fig,axes=plt.subplots(\n",
        "    6,\n",
        "    4,\n",
        "    figsize=(8,12)\n",
        ")\n",
        "\n",
        "\n",
        "axes=axes.flatten()\n",
        "\n",
        "\n",
        "\n",
        "for ax,(letra,data) in zip(\n",
        "    axes,\n",
        "    tmaqT.items()\n",
        "):\n",
        "\n",
        "    matriz=np.array(\n",
        "        data[\"patron\"]\n",
        "    )\n",
        "\n",
        "\n",
        "    ax.imshow(\n",
        "        matriz,\n",
        "        cmap=\"binary\",\n",
        "        interpolation=\"nearest\"\n",
        "    )\n",
        "\n",
        "\n",
        "    ax.set_title(\n",
        "        letra\n",
        "    )\n",
        "\n",
        "\n",
        "    ax.axis(\"off\")\n",
        "\n",
        "\n",
        "\n",
        "plt.suptitle(\n",
        "    \"N1 - Alfabeto TmaqT\\n24 matrices 5x5 / 9 negros\"\n",
        ")\n",
        "\n",
        "plt.tight_layout()\n",
        "\n",
        "plt.show()"
      ],
